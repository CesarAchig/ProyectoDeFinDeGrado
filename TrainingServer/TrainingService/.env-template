##########################
# Variables Obligatorias #
##########################

# API key para el LLM de OpenCode
OPENCODE_API_KEY="sk-..."

# IP privada del servidor MLflow
MLFLOW_SERVER_IP="10.0.x.x"

# Nombre del bucket S3 con los datasets de usuario
DATASET_BUCKET_NAME="datasets-pfg-s3"

# Nombre de la tabla DynamoDB de jobs
DYNAMODB_JOBS_TABLE="training-jobs-table"


##########################
#  Variables Opcionales  #
##########################

# Modelo de LLM (default: kimi-k2.6)
# OPENCODE_MODEL="kimi-k2.6"

# URL base de la API del LLM (default: https://opencode.ai/zen/go/v1)
# OPENCODE_BASE_URL="https://opencode.ai/zen/go/v1"

# Puerto del servidor MLflow (default: 8080)
# MLFLOW_SERVER_PORT="8080"
